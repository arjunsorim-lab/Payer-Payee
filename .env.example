# Local development
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=PayerPayee
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://payer-payee-1.onrender.com
CSV_PATH=/Users/user/Downloads/EDI_834_837_20 members(837_Claims).csv
SAVINGS_WORKBOOK_PATH=/Users/user/Downloads/claims_with_dummy_savings_fields.xlsx
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_CACHE_TTL_SECONDS=900
GROQ_TIMEOUT_SECONDS=15
PROVIDER_EPISODE_WINDOW_DAYS=90
PROVIDER_MIN_PEERS=5

# Render service
RENDER_SERVICE_NAME=payer-payee
RENDER_SERVICE_URL=https://payer-payee-1.onrender.com
PYTHON_VERSION=3.12.8

# Copy these values into Render's Environment tab.
# Do not use mongodb://localhost:27017/ on Render; use MongoDB Atlas or another hosted MongoDB URI.
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/PayerPayee?retryWrites=true&w=majority
