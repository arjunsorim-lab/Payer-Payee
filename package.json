{
  "name": "payerpayee",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run frontend",
    "frontend": "vite --config frontend/vite.config.js",
    "backend": "python3 -m backend.app",
    "backend:start": "gunicorn backend.app:app --bind 0.0.0.0:${PORT:-4000}",
    "dev:all": "concurrently -k -n backend,frontend -c blue,green \"npm:backend\" \"npm:frontend\"",
    "import:mongo": "python3 -m backend.import_claims",
    "export:fallback": "python3 -m backend.export_fallback",
    "report:provider-llm": "python3 -m backend.provider_batch_report",
    "test:backend": "python3 -m unittest discover -s backend/tests -v",
    "test:frontend": "node --test frontend/src/providerLlmFormat.test.js",
    "test": "npm run test:backend && npm run test:frontend",
    "build": "vite build --config frontend/vite.config.js",
    "lint": "oxlint",
    "preview": "vite preview --config frontend/vite.config.js"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
